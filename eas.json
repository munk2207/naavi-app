{
  "cli": {
    "version": ">= 15.0.0",
    "requireCommit": true
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_TEST_LOGIN_ENABLED": "true"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "trial-debug": {
      "distribution": "internal",
      "env": {
        "EXPO_DEBUGGABLE_RELEASE": "true"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {}
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": false
      }
    }
  }
}
