# Naavi auto-tester — local secrets.
#
# Copy this file to tests/.env and fill in real values.
# tests/.env is gitignored — never commit your real keys.

# 1. Supabase project URL.
SUPABASE_URL=https://hhgyppbxgmjrwdpdubcx.supabase.co

# 2. Anon (publishable) key — same one the mobile app uses (EXPO_PUBLIC_SUPABASE_ANON_KEY).
#    Find it: Supabase Dashboard → Project Settings → API → "Project API keys" → anon / public.
SUPABASE_ANON_KEY=

# 3. Service role key — DANGEROUS. Bypasses RLS. Used only for fixture
#    setup/teardown and server-side test reads. Never put this in client code.
#    Find it: Supabase Dashboard → Project Settings → API → "Project API keys" → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# 4. Dedicated test user id. Must be a real row in auth.users.
#    Recommended: create a Google account naavi-tester@…, sign into the mobile
#    app once so auth.users has a row, then copy that user_id here.
#    The suite deletes rows owned by this user — do NOT use a real user.
TEST_USER_ID=
