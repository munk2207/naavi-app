{
  "expo": {
    "name": "MyNaavi",
    "slug": "naavi",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/be293d9d-cab2-48ff-85a5-d27187ff4340"
    },
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ca.naavi.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "MyNaavi uses the microphone so Robert can speak to it.",
        "NSSpeechRecognitionUsageDescription": "MyNaavi listens to Robert's voice to understand his requests.",
        "NSHealthShareUsageDescription": "MyNaavi reads health data to include it in Robert's daily brief."
      }
    },
    "android": {
      "versionCode": 214,
      "softwareKeyboardLayoutMode": "pan",
      "package": "ca.naavi.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECORD_AUDIO",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-localization",
      "./plugins/withAppActions",
      "./plugins/withDebuggableRelease",
      "expo-updates",
      "@mykin-ai/expo-audio-stream",
      "expo-contacts",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5DCAA5"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "MyNaavi uses your location to alert you when you arrive at or leave places you care about (like home, Costco, or the cottage). Your location is used only to trigger alerts you've set up, never shared, and not stored as history.",
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": false
        }
      ],
      "expo-web-browser",
      "expo-gradle-ext-vars",
      [
        "react-native-background-geolocation",
        {
          "license": "eyJhbGciOiJFZERTQSIsImtpZCI6ImVkMjU1MTktbWFpbi12MSJ9..wMtWns6_Siky7sB-UqQ-IgAAF7KzinwD9CDva0UCVq_TDoZcO7hbgNMfBH3yz6GH6YhVtfbH-NzTp10SAicdDQ"
        }
      ]
    ],
    "scheme": "naavi",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "be293d9d-cab2-48ff-85a5-d27187ff4340"
      }
    }
  }
}