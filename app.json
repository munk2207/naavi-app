{
  "expo": {
    "name": "MyNaavi",
    "slug": "naavi",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/be293d9d-cab2-48ff-85a5-d27187ff4340"
    },
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ca.naavi.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "MyNaavi uses the microphone so Robert can speak to it.",
        "NSSpeechRecognitionUsageDescription": "MyNaavi listens to Robert's voice to understand his requests.",
        "NSHealthShareUsageDescription": "MyNaavi reads health data to include it in Robert's daily brief."
      }
    },
    "android": {
      "versionCode": 30,
      "package": "ca.naavi.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECORD_AUDIO",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-localization",
      "./plugins/withAppActions",
      "expo-updates"
    ],
    "scheme": "naavi",
    "extra": {
      "appVersion": "V35",
      "router": {},
      "eas": {
        "projectId": "be293d9d-cab2-48ff-85a5-d27187ff4340"
      }
    }
  }
}
